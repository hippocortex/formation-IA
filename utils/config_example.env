# ==============================
# Environnement IA - Formation Agents & LLM
# ==============================

# Clé API OpenAI (à obtenir sur https://platform.openai.com/account/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Optionnel : configuration du modèle par défaut
OPENAI_MODEL=gpt-4o-mini

# Optionnel : si tu utilises un proxy ou un endpoint spécifique
OPENAI_BASE_URL=https://api.openai.com/v1

# ==============================
# Variables pour tests ou extensions (ex: intégrations API externes)
# ==============================

# Exemple : clé API HuggingFace (si besoin pour comparaison de modèles)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Exemple : clé API LangChain Hub (si tu utilises LangChain avec des notebooks dédiés)
LANGCHAIN_API_KEY=your_langchain_api_key_here

# ==============================
# Paramètres optionnels
# ==============================

# Contrôle du mode d’exécution (mock = sans appel API réel)
EXECUTION_MODE=real
# EXECUTION_MODE=mock
